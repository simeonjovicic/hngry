{%- liquid
  assign product = section.settings.product
-%}

<script src="{{ 'hngry-reveal.js' | asset_url }}" defer></script>

<section class="hngry-featured" {{ section.shopify_attributes }}>
  <div class="hngry-featured__head">
    <p class="hngry-featured__label hngry-mono hngry-reveal hngry-reveal--soft">{{ section.settings.label }}</p>
    <h2 class="hngry-featured__title hngry-display hngry-reveal hngry-reveal--soft" style="--hngry-reveal-delay: 100ms;">{{ section.settings.heading }}</h2>
  </div>

  {%- if product != blank -%}
    <div class="hngry-featured__grid page-width">
      {%- liquid
        assign main_media = product.media[0]
        assign hover_media = product.media[1]
      -%}

      <a href="{{ product.url }}" class="hngry-featured__media hngry-reveal hngry-reveal--scale">
        {%- if section.settings.badge != blank -%}
          <span class="hngry-featured__badge hngry-mono">{{ section.settings.badge }}</span>
        {%- endif -%}
        {%- if main_media != blank -%}
          <img
            src="{{ main_media | image_url: width: 1100 }}"
            alt="{{ main_media.alt | default: product.title | escape }}"
            loading="lazy"
            width="{{ main_media.preview_image.width }}"
            height="{{ main_media.preview_image.height }}"
            class="hngry-featured__img"
          >
        {%- else -%}
          <span class="hngry-featured__noimg hngry-mono">NO PRODUCT IMAGE YET</span>
        {%- endif -%}
        {%- if hover_media != blank -%}
          <img
            src="{{ hover_media | image_url: width: 1100 }}"
            alt="{{ hover_media.alt | default: product.title | escape }}"
            loading="lazy"
            width="{{ hover_media.width }}"
            height="{{ hover_media.height }}"
            class="hngry-featured__img hngry-featured__img--hover"
            aria-hidden="true"
          >
        {%- endif -%}
      </a>

      <div class="hngry-featured__panel">
        <h3 class="hngry-featured__name hngry-display hngry-reveal hngry-reveal--right">{{ product.title }}</h3>
        <p class="hngry-featured__price hngry-mono hngry-reveal hngry-reveal--right" style="--hngry-reveal-delay: 90ms;">
          {{ product.price | money }}
          <span class="hngry-featured__price-sub">{{ section.settings.sub_label }}</span>
        </p>

        <div class="hngry-featured__divider"></div>

        {%- form 'product', product, class: 'hngry-featured__form hngry-reveal hngry-reveal--right', style: '--hngry-reveal-delay: 180ms;' -%}
          {%- if product.has_only_default_variant -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          {%- else -%}
            <p class="hngry-featured__size-label hngry-mono">SIZE:</p>
            <div class="hngry-featured__sizes">
              {%- for variant in product.variants -%}
                <label class="hngry-featured__size{% unless variant.available %} hngry-featured__size--soldout{% endunless %}">
                  <input
                    type="radio"
                    name="id"
                    value="{{ variant.id }}"
                    {% unless variant.available %}disabled{% endunless %}
                    required
                  >
                  <span class="hngry-mono">{{ variant.title }}</span>
                </label>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="hngry-featured__buy">
            <div class="hngry-featured__qty hngry-mono">
              <button type="button" data-qty-minus aria-label="{{ 'products.product.quantity.decrease' | t: product: product.title | escape }}">−</button>
              <input type="number" name="quantity" value="1" min="1" aria-label="{{ 'products.product.quantity.label' | t | escape }}">
              <button type="button" data-qty-plus aria-label="{{ 'products.product.quantity.increase' | t: product: product.title | escape }}">+</button>
            </div>
            <button
              type="submit"
              class="hngry-featured__submit hngry-mono"
              {% unless product.available %}disabled{% endunless %}
            >
              {%- if product.available -%}ADD TO BAG{%- else -%}SOLD OUT{%- endif -%}
            </button>
          </div>

          <p class="hngry-featured__payments hngry-mono">
            VISA / MASTERCARD / APPLE PAY / GOOGLE PAY<br>
            SECURE CHECKOUT
          </p>
        {%- endform -%}

        <div class="hngry-featured__divider"></div>

        <a href="{{ product.url }}" class="hngry-featured__details hngry-mono hngry-reveal hngry-reveal--right" style="--hngry-reveal-delay: 270ms;">
          VIEW PRODUCT DETAILS →
        </a>
      </div>
    </div>
  {%- else -%}
    <div class="hngry-featured__grid page-width">
      <div class="hngry-featured__media hngry-featured__media--empty hngry-mono">
        SELECT A PRODUCT IN THE THEME EDITOR
      </div>
    </div>
  {%- endif -%}
</section>

<script>
  (function () {
    document.querySelectorAll('.hngry-featured__qty').forEach(function (qty) {
      var input = qty.querySelector('input');
      qty.querySelector('[data-qty-minus]').addEventListener('click', function () {
        input.value = Math.max(1, parseInt(input.value || '1', 10) - 1);
      });
      qty.querySelector('[data-qty-plus]').addEventListener('click', function () {
        input.value = parseInt(input.value || '1', 10) + 1;
      });
    });
  })();
</script>

{% style %}
  .hngry-featured {
    padding: 7rem 0 8rem;
    background: var(--hngry-bone);
    color: var(--hngry-ink);
    border-bottom: 1px solid rgba(12, 12, 12, 0.15);
  }

  .hngry-featured__head { text-align: center; }

  .hngry-featured__label {
    font-size: 1.1rem;
    letter-spacing: 0.3em;
    color: rgba(12, 12, 12, 0.4);
    margin: 0;
  }

  .hngry-featured__title {
    margin: 1rem 0 0;
    font-size: clamp(3rem, 3.8vw, 4.6rem);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .hngry-featured__grid {
    display: grid;
    gap: 3rem;
    margin-top: 5rem;
    max-width: 120rem;
  }

  @media (min-width: 750px) {
    .hngry-featured__grid {
      grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
      align-items: center;
      gap: 6rem;
      margin-top: 5.5rem;
    }
  }

  /* product photo — crisp hairline frame; hover = zoom + soft blur + vignette
     (+ flip to second media), so it clearly reads as a clickable product */
  .hngry-featured__media {
    position: relative;
    display: block;
    overflow: hidden;
    background: var(--hngry-smoke);
    border: 1px solid rgba(12, 12, 12, 0.1);
    transition: border-color 0.3s;
    cursor: pointer;
  }

  .hngry-featured__media:hover { border-color: rgba(12, 12, 12, 0.35); }

  /* vignette overlay, fades in on hover */
  .hngry-featured__media::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: radial-gradient(
      ellipse at center,
      transparent 50%,
      rgba(12, 12, 12, 0.32) 100%
    );
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .hngry-featured__media:hover::after { opacity: 1; }

  .hngry-featured__media--empty,
  .hngry-featured__noimg {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1 / 1;
    font-size: 1.1rem;
    color: rgba(12, 12, 12, 0.4);
  }

  .hngry-featured__img {
    display: block;
    width: 100%;
    height: auto;
    transform: scale(1);
    filter: blur(0);
    transition: transform 0.7s ease, filter 0.7s ease;
  }

  .hngry-featured__media:hover .hngry-featured__img {
    transform: scale(1.05);
    filter: blur(1.5px);
  }

  .hngry-featured__img--hover {
    position: absolute;
    inset: 0;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transform: scale(1);
    transition: opacity 0.5s, transform 0.7s ease;
  }

  /* the back-print flip zooms with the hover and stays crisp on top */
  .hngry-featured__media:hover .hngry-featured__img--hover {
    opacity: 1;
    transform: scale(1.05);
    filter: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .hngry-featured__img,
    .hngry-featured__img--hover,
    .hngry-featured__media::after {
      transition: none;
    }
    .hngry-featured__media:hover .hngry-featured__img,
    .hngry-featured__media:hover .hngry-featured__img--hover {
      transform: none;
      filter: none;
    }
  }

  .hngry-featured__badge {
    position: absolute;
    top: 1.2rem;
    left: 1.2rem;
    z-index: 2;
    background: var(--hngry-ink);
    color: var(--hngry-bone);
    padding: 0.4rem 0.8rem;
    font-size: 1rem;
  }

  /* buy panel */
  .hngry-featured__panel {
    width: 100%;
    max-width: 50rem;
  }

  .hngry-featured__name {
    margin: 0;
    font-size: clamp(2.8rem, 3vw, 3.6rem);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hngry-featured__price {
    margin: 1rem 0 0;
    font-size: 1.8rem;
    letter-spacing: 0.05em;
  }

  .hngry-featured__price-sub {
    margin-left: 1rem;
    font-size: 1.1rem;
    letter-spacing: 0.2em;
    color: rgba(12, 12, 12, 0.4);
  }

  /* doubled class beats Dawn's `div:empty { display: none }` in base.css */
  .hngry-featured__panel .hngry-featured__divider {
    display: block;
    margin: 2.8rem 0;
    border-top: 1px solid rgba(12, 12, 12, 0.1);
  }

  .hngry-featured__size-label {
    margin: 0 0 1rem;
    font-size: 1.1rem;
  }

  .hngry-featured__sizes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .hngry-featured__size input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .hngry-featured__size span {
    display: inline-block;
    min-width: 6rem;
    border: 1px solid var(--hngry-ink);
    padding: 1.1rem 1.4rem;
    font-size: 1.1rem;
    text-align: center;
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s;
  }

  .hngry-featured__size:hover span,
  .hngry-featured__size input:checked + span {
    background: var(--hngry-ink);
    color: var(--hngry-bone);
  }

  .hngry-featured__size input:focus-visible + span {
    outline: 2px solid var(--hngry-tag);
    outline-offset: 2px;
  }

  .hngry-featured__size--soldout span {
    border-color: rgba(12, 12, 12, 0.3);
    color: rgba(12, 12, 12, 0.3);
    text-decoration: line-through;
    cursor: not-allowed;
  }

  .hngry-featured__size--soldout:hover span {
    background: transparent;
    color: rgba(12, 12, 12, 0.3);
  }

  .hngry-featured__buy {
    display: flex;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .hngry-featured__qty {
    display: flex;
    align-items: center;
    border: 1px solid var(--hngry-ink);
  }

  .hngry-featured__qty button {
    background: none;
    border: none;
    padding: 1.4rem 1.4rem;
    font-size: 1.3rem;
    color: var(--hngry-ink);
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s;
  }

  .hngry-featured__qty button:hover {
    background: var(--hngry-ink);
    color: var(--hngry-bone);
  }

  .hngry-featured__qty input {
    width: 4rem;
    background: transparent;
    border: none;
    font-family: var(--hngry-mono);
    font-size: 1.3rem;
    text-align: center;
    color: var(--hngry-ink);
    -moz-appearance: textfield;
    appearance: textfield;
  }

  .hngry-featured__qty input::-webkit-outer-spin-button,
  .hngry-featured__qty input::-webkit-inner-spin-button {
    -webkit-appearance: none;
  }

  .hngry-featured__submit {
    flex: 1;
    border: 1px solid var(--hngry-ink);
    background: var(--hngry-ink);
    color: var(--hngry-bone);
    padding: 1.4rem;
    font-size: 1.2rem;
    letter-spacing: 0.25em;
    cursor: pointer;
    transition: background-color 0.2s, border-color 0.2s;
  }

  .hngry-featured__submit:hover {
    background: var(--hngry-tag);
    border-color: var(--hngry-tag);
  }

  .hngry-featured__submit:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .hngry-featured__payments {
    margin: 1.6rem 0 0;
    font-size: 0.95rem;
    line-height: 1.9;
    letter-spacing: 0.2em;
    text-align: center;
    color: rgba(12, 12, 12, 0.4);
  }

  .hngry-featured__details {
    font-size: 1.1rem;
    color: rgba(12, 12, 12, 0.6);
    text-decoration: underline;
    text-underline-offset: 0.8rem;
    transition: color 0.2s;
  }

  .hngry-featured__details:hover { color: var(--hngry-ink); }
{% endstyle %}

{% schema %}
{
  "name": "HNGRY Featured Product",
  "settings": [
    { "type": "product", "id": "product", "label": "Product" },
    { "type": "text", "id": "label", "label": "Label", "default": "(02) — THE DROP" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured Product" },
    { "type": "text", "id": "badge", "label": "Badge on image", "default": "NEW" },
    {
      "type": "text",
      "id": "sub_label",
      "label": "Sub label next to price",
      "default": "WHITE / DROP 001"
    }
  ],
  "presets": [{ "name": "HNGRY Featured Product" }]
}
{% endschema %}
