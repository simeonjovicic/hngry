{{ 'hngry.css' | asset_url | stylesheet_tag }}
<script src="{{ 'hngry-teaser.js' | asset_url }}" defer></script>

{%- liquid
  if section.settings.logo != blank
    assign logo_url = section.settings.logo | image_url: width: 1080
  else
    assign logo_url = 'hngry-logo.png' | asset_url
  endif
-%}

<div
  class="hngry-teaser"
  data-hngry-teaser
  data-logo-src="{{ logo_url }}"
  data-drop-date="{{ section.settings.drop_date | escape }}"
>
  <canvas class="hngry-teaser__canvas" aria-label="{{ shop.name }} — coming soon"></canvas>
  <img
    src="{{ logo_url }}"
    alt="{{ shop.name }}"
    class="hngry-teaser__fallback hngry-logo-invert"
    data-teaser-fallback
    width="1080"
    height="1080"
  >

  <div class="hngry-teaser__labels hngry-mono">
    <span class="hngry-rise" style="animation-delay: 400ms">{{ section.settings.label_top_left }}</span>
    <span class="hngry-rise" style="animation-delay: 550ms">{{ section.settings.label_top_right }}</span>
    <span class="hngry-rise" style="animation-delay: 700ms">{{ section.settings.label_bottom_left }}</span>
    <span class="hngry-rise hngry-teaser__label-desktop" style="animation-delay: 850ms">{{ section.settings.label_bottom_right }}</span>
  </div>

  <div class="hngry-teaser__gate">
    <div class="hngry-teaser__countdown hngry-rise" style="animation-delay: 1100ms">
      {%- assign units = 'DAYS,HRS,MIN,SEC' | split: ',' -%}
      {%- for unit in units -%}
        <div class="hngry-teaser__count-cell">
          <span class="hngry-display" data-count-{{ unit | downcase }}>––</span>
          <small class="hngry-mono">{{ unit }}</small>
        </div>
      {%- endfor -%}
    </div>

    {%- form 'storefront_password', class: 'hngry-teaser__form hngry-rise' -%}
      <div class="hngry-teaser__form-row{% if form.errors %} hngry-shake{% endif %}">
        <input
          type="password"
          name="password"
          placeholder="PASSWORD"
          autocomplete="off"
          aria-describedby="HngryPasswordError-{{ section.id }}"
          {% if form.errors %}aria-invalid="true"{% endif %}
          class="hngry-teaser__input hngry-mono"
        >
        <button type="submit" class="hngry-teaser__submit hngry-mono" aria-label="Enter">→</button>
      </div>
      <p
        id="HngryPasswordError-{{ section.id }}"
        class="hngry-teaser__error hngry-mono{% if form.errors %} is-visible{% endif %}"
        role="status"
        aria-live="polite"
      >
        WRONG. STAY HUNGRY.
      </p>
    {%- endform -%}

    {%- if section.settings.whatsapp_url != blank -%}
      <div class="hngry-teaser__early hngry-rise">
        <a
          href="{{ section.settings.whatsapp_url }}"
          class="hngry-teaser__whatsapp hngry-mono"
          target="_blank"
          rel="noopener"
        >
          <span class="hngry-teaser__whatsapp-kicker">GET THE CODE FIRST</span>
          <span class="hngry-teaser__whatsapp-label">{{ section.settings.whatsapp_label }} ↗</span>
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% style %}
  .hngry-teaser {
    position: fixed;
    inset: 0;
    overflow: hidden;
    background: #0d0d0c;
    color: var(--hngry-bone);
    font-family: var(--hngry-sans);
    z-index: 50;
  }

  .hngry-teaser__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hngry-teaser__fallback {
    display: none;
    position: absolute;
    left: 50%;
    top: 45%;
    transform: translate(-50%, -50%);
    width: 60%;
    max-width: 560px;
    height: auto;
  }

  .hngry-teaser__labels {
    position: absolute;
    inset: 0;
    pointer-events: none;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.6);
  }

  .hngry-teaser__labels span {
    position: absolute;
  }

  .hngry-teaser__labels span:nth-child(1) { top: 2rem; left: 2rem; }
  .hngry-teaser__labels span:nth-child(2) { top: 2rem; right: 2rem; }
  .hngry-teaser__labels span:nth-child(3) { bottom: 2rem; left: 2rem; }
  .hngry-teaser__labels span:nth-child(4) { bottom: 2rem; right: 2rem; }

  @media (max-width: 749px) {
    .hngry-teaser__label-desktop { display: none; }
  }

  .hngry-teaser__gate {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 10%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    padding: 0 1.5rem;
    transition: opacity 0.7s ease;
  }

  .hngry-teaser.is-unlocking .hngry-teaser__gate {
    pointer-events: none;
    opacity: 0;
  }

  .hngry-teaser__countdown {
    display: flex;
    gap: 2.5rem;
  }

  @media (max-width: 749px) {
    .hngry-teaser__countdown { gap: 1.5rem; }
  }

  .hngry-teaser__count-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .hngry-teaser__count-cell .hngry-display {
    font-family: "Anton", "Arial Black", sans-serif;
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    font-variant-numeric: tabular-nums;
  }

  .hngry-teaser__count-cell small {
    font-size: 10px;
    letter-spacing: 0.35em;
    color: rgba(255, 255, 255, 0.4);
  }

  .hngry-teaser__form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: 20rem;
    animation-delay: 1350ms;
  }

  .hngry-teaser__form-row {
    display: flex;
    align-items: flex-end;
    gap: 0.75rem;
    width: 100%;
  }

  .hngry-teaser__input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
    padding: 0 0 0.5rem;
    text-align: center;
    color: var(--hngry-bone);
    font-size: 14px;
    letter-spacing: 0.4em;
    outline: none;
    border-radius: 0;
    transition: border-color 0.2s;
  }

  .hngry-teaser__input:focus {
    border-color: var(--hngry-bone);
  }

  .hngry-teaser.is-checking .hngry-teaser__input {
    opacity: 0.55;
  }

  .hngry-teaser__input::placeholder {
    color: rgba(255, 255, 255, 0.25);
  }

  .hngry-teaser__submit {
    background: none;
    border: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
    padding: 0 0 0.5rem;
    color: var(--hngry-bone);
    font-size: 14px;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }

  .hngry-teaser__submit:hover {
    border-color: var(--hngry-bone);
    color: var(--hngry-tag);
  }

  .hngry-teaser__submit:disabled {
    cursor: wait;
    color: var(--hngry-tag);
    opacity: 0.8;
  }

  .hngry-teaser__error {
    margin: 0;
    font-size: 10px;
    color: var(--hngry-tag);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .hngry-teaser__error.is-visible {
    opacity: 1;
  }

  .hngry-teaser__early {
    width: 100%;
    max-width: 20rem;
    text-align: center;
    animation-delay: 1500ms;
    transition: opacity 0.35s ease;
  }

  .hngry-teaser__whatsapp {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    width: 100%;
    padding: 0.45rem 0 0.6rem;
    color: rgba(255, 255, 255, 0.62);
    background: transparent;
    border: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .hngry-teaser__whatsapp:hover {
    color: var(--hngry-bone);
    background: transparent;
    border-color: rgba(255, 255, 255, 0.55);
  }

  .hngry-teaser__whatsapp-kicker {
    font-size: 7px;
    letter-spacing: 0.24em;
    opacity: 0.4;
  }

  .hngry-teaser__whatsapp-label {
    font-size: 9px;
    letter-spacing: 0.16em;
  }

  .hngry-teaser.is-public-access-time .hngry-teaser__early {
    opacity: 0.35;
    pointer-events: none;
  }
{% endstyle %}

{% schema %}
{
  "name": "HNGRY Password",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (transparent PNG)",
      "info": "Falls back to the bundled HNGRY logo"
    },
    {
      "type": "text",
      "id": "drop_date",
      "label": "Drop date (ISO)",
      "default": "2026-07-27T20:00:00+02:00",
      "info": "Format: YYYY-MM-DDTHH:MM:SS+02:00"
    },
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "WhatsApp early-access invite link"
    },
    {
      "type": "text",
      "id": "whatsapp_label",
      "label": "WhatsApp button label",
      "default": "JOIN WHATSAPP"
    },
    {
      "type": "text",
      "id": "label_top_left",
      "label": "Top left label",
      "default": "HNGRŸ®"
    },
    {
      "type": "text",
      "id": "label_top_right",
      "label": "Top right label",
      "default": "DROP 001 — SUMMER 26"
    },
    {
      "type": "text",
      "id": "label_bottom_left",
      "label": "Bottom left label",
      "default": "27.07.2026 — 20:00"
    },
    {
      "type": "text",
      "id": "label_bottom_right",
      "label": "Bottom right label",
      "default": "STAY HNGRŸ"
    }
  ],
  "presets": [{ "name": "HNGRY Password" }]
}
{% endschema %}
