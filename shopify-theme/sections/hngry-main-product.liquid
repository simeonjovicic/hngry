<script src="{{ 'hngry-reveal.js' | asset_url }}" defer></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign current = product.selected_or_first_available_variant
  assign details = section.settings.details | strip | newline_to_br | split: '<br />'
  assign product_form_id = 'hngry-product-form-' | append: section.id
-%}

<section class="hngry-pdp color-{{ section.settings.color_scheme }}" {{ section.shopify_attributes }}>
  <div class="page-width">
    <a href="{{ routes.root_url }}" class="hngry-pdp__back hngry-mono">&larr; BACK TO HOME</a>

    <div class="hngry-pdp__grid">
      {%- comment -%} media column {%- endcomment -%}
      <div class="hngry-pdp__media hngry-reveal">
        <div class="hngry-pdp__main">
          {%- unless product.available -%}
            <span class="hngry-pdp__badge hngry-mono">SOLD OUT</span>
          {%- else -%}
            {%- if section.settings.badge != blank -%}
              <span class="hngry-pdp__badge hngry-mono">{{ section.settings.badge }}</span>
            {%- endif -%}
          {%- endunless -%}

          {%- if product.featured_image -%}
            <img
              src="{{ product.featured_image | image_url: width: 1400 }}"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              width="{{ product.featured_image.width }}"
              height="{{ product.featured_image.height }}"
              class="hngry-pdp__img"
            >
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'hngry-pdp__img hngry-pdp__img--placeholder' }}
          {%- endif -%}
        </div>

        {%- if product.images.size > 1 -%}
          <div class="hngry-pdp__thumbs">
            {%- for image in product.images offset: 1 limit: 3 -%}
              <img
                src="{{ image | image_url: width: 500 }}"
                alt="{{ image.alt | default: product.title | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
                class="hngry-pdp__thumb"
              >
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} info column {%- endcomment -%}
      <div class="hngry-pdp__info hngry-reveal">
        <h1 class="hngry-pdp__title hngry-display">{{ product.title }}</h1>

        {%- if section.settings.sub_label != blank -%}
          <p class="hngry-pdp__sublabel hngry-mono">{{ section.settings.sub_label }}</p>
        {%- endif -%}

        <p class="hngry-pdp__price hngry-mono">
          {%- if product.compare_at_price > product.price -%}
            <span class="hngry-pdp__was">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
          {{ current.price | money }}
        </p>

        {%- if product.description != blank -%}
          <div class="hngry-pdp__desc">{{ product.description }}</div>
        {%- endif -%}

        <product-form class="product-form hngry-pdp__product-form" data-section-id="{{ section.id }}">
          <div class="product-form__error-message-wrapper" role="alert" hidden>
            <span class="product-form__error-message"></span>
          </div>

          {%- form 'product', product, id: product_form_id, class: 'hngry-pdp__form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
            {%- unless product.has_only_default_variant -%}
              <fieldset class="hngry-pdp__variants">
                <legend class="hngry-pdp__variants-label hngry-mono">SELECT SIZE</legend>
                <div class="hngry-pdp__sizes">
                  {%- for variant in product.variants -%}
                    <label class="hngry-pdp__size{% unless variant.available %} is-soldout{% endunless %}">
                      <input
                        type="radio"
                        name="id"
                        value="{{ variant.id }}"
                        {% if variant.available %}{% if variant == current %}checked{% endif %}{% else %}disabled{% endif %}
                      >
                      <span>{{ variant.title }}</span>
                    </label>
                  {%- endfor -%}
                </div>
              </fieldset>
            {%- else -%}
              <input type="hidden" name="id" value="{{ current.id }}" class="product-variant-id">
            {%- endunless -%}

            <button
              type="submit"
              name="add"
              class="hngry-pdp__add product-form__submit hngry-mono"
              {% unless product.available %}disabled{% endunless %}
            >
              <span>{%- if product.available -%}ADD TO BAG &rarr;{%- else -%}SOLD OUT{%- endif -%}</span>
              {%- render 'loading-spinner' -%}
            </button>
          {%- endform -%}
        </product-form>

        {%- if details.size > 0 and section.settings.details != blank -%}
          <div class="hngry-pdp__details">
            <p class="hngry-pdp__details-label hngry-mono">DETAILS</p>
            <ul class="hngry-pdp__details-list">
              {%- for line in details -%}
                {%- assign clean = line | strip -%}
                {%- if clean != blank -%}
                  <li class="hngry-mono">&#10022; {{ clean | upcase }}</li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% style %}
  .hngry-pdp {
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    padding: 3rem 0 5rem;
  }

  .hngry-pdp__back {
    display: inline-block;
    font-size: 0.95rem;
    letter-spacing: 0.25em;
    color: inherit;
    text-decoration: none;
  }

  .hngry-pdp__back:hover { text-decoration: underline; text-underline-offset: 4px; }

  .hngry-pdp__grid {
    display: grid;
    gap: 3rem;
    margin-top: 2.5rem;
  }

  @media (min-width: 990px) {
    .hngry-pdp__grid { grid-template-columns: 1fr 1fr; gap: 4rem; }
  }

  .hngry-pdp__main {
    position: relative;
    background: rgba(var(--color-foreground), 0.05);
  }

  .hngry-pdp__badge {
    position: absolute;
    top: 1.1rem;
    left: 1.1rem;
    z-index: 1;
    padding: 0.4rem 0.7rem;
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    font-size: 0.8rem;
    letter-spacing: 0.2em;
  }

  .hngry-pdp__img { display: block; width: 100%; height: auto; border-radius: 8px; }

  .hngry-pdp__thumbs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }

  .hngry-pdp__thumb {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 8px;
    background: rgba(var(--color-foreground), 0.05);
  }

  .hngry-pdp__info { max-width: 34rem; }

  .hngry-pdp__title {
    margin: 0;
    font-size: clamp(2.8rem, 4vw, 3.6rem);
    line-height: 0.95;
    text-transform: uppercase;
  }

  .hngry-pdp__sublabel {
    margin: 0.6rem 0 0;
    font-size: 0.95rem;
    letter-spacing: 0.25em;
    opacity: 0.5;
  }

  .hngry-pdp__price {
    margin: 1.4rem 0 0;
    font-size: 1.5rem;
  }

  .hngry-pdp__was {
    margin-right: 0.8rem;
    opacity: 0.4;
    text-decoration: line-through;
  }

  .hngry-pdp__desc {
    margin-top: 1.6rem;
    padding-left: 1.1rem;
    border-left: 2px solid rgb(var(--color-foreground));
    font-size: 1rem;
    line-height: 1.7;
    opacity: 0.85;
  }

  .hngry-pdp__desc > * { margin: 0 0 0.8rem; }
  .hngry-pdp__desc > *:last-child { margin-bottom: 0; }

  .hngry-pdp__form { margin-top: 2.2rem; }

  .hngry-pdp__variants { border: none; padding: 0; margin: 0 0 1.6rem; }

  .hngry-pdp__variants-label {
    padding: 0;
    font-size: 0.85rem;
    letter-spacing: 0.25em;
    opacity: 0.55;
  }

  .hngry-pdp__sizes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1rem;
  }

  .hngry-pdp__size {
    position: relative;
    cursor: pointer;
  }

  .hngry-pdp__size input {
    position: absolute;
    opacity: 0;
    inset: 0;
    cursor: pointer;
  }

  .hngry-pdp__size span {
    display: grid;
    place-items: center;
    min-width: 3.2rem;
    padding: 0.7rem 1rem;
    border: 1px solid rgba(var(--color-foreground), 0.4);
    font-family: var(--hngry-sans);
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
  }

  .hngry-pdp__size input:checked + span {
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    border-color: rgb(var(--color-foreground));
  }

  .hngry-pdp__size input:focus-visible + span {
    outline: 2px solid var(--hngry-tag);
    outline-offset: 2px;
  }

  .hngry-pdp__size.is-soldout span {
    opacity: 0.35;
    text-decoration: line-through;
    cursor: not-allowed;
  }

  .hngry-pdp__product-form { display: block; }

  .hngry-pdp__add {
    position: relative;
    width: 100%;
    padding: 1.15rem;
    border: none;
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    font-size: 0.95rem;
    letter-spacing: 0.25em;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .hngry-pdp__add:hover { opacity: 0.85; }
  .hngry-pdp__add:disabled { opacity: 0.4; cursor: not-allowed; }
  .hngry-pdp__add[aria-disabled='true'] { opacity: 0.6; cursor: wait; }

  .hngry-pdp__add.loading > span { visibility: hidden; }

  .hngry-pdp__add .loading__spinner {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
  }

  .hngry-pdp__add .loading__spinner .spinner { width: 1.4rem; height: 1.4rem; }
  .hngry-pdp__add .loading__spinner path { fill: rgb(var(--color-background)); }

  .hngry-pdp__product-form .product-form__error-message-wrapper {
    margin-top: 1rem;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: var(--hngry-tag);
  }

  .product-form__error-message-wrapper[hidden] { display: none; }

  .hngry-pdp__details {
    margin-top: 2.6rem;
    padding-top: 1.6rem;
    border-top: 1px solid rgba(var(--color-foreground), 0.15);
  }

  .hngry-pdp__details-label {
    margin: 0 0 1rem;
    font-size: 0.85rem;
    letter-spacing: 0.25em;
  }

  .hngry-pdp__details-list { margin: 0; padding: 0; list-style: none; }

  .hngry-pdp__details-list li {
    font-size: 0.85rem;
    line-height: 1.9;
    letter-spacing: 0.08em;
    opacity: 0.6;
  }

  .js-reveal .hngry-pdp .hngry-reveal {
    opacity: 0;
    transform: translateY(1.6rem);
    transition:
      opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .js-reveal .hngry-pdp .hngry-reveal:nth-child(2) { transition-delay: 100ms; }
  .js-reveal .hngry-pdp .hngry-reveal.is-visible { opacity: 1; transform: none; }

  @media (prefers-reduced-motion: reduce) {
    .js-reveal .hngry-pdp .hngry-reveal { opacity: 1; transform: none; transition: none; }
  }

  /* desktop — much larger, more readable product-detail text */
  @media (min-width: 990px) {
    .hngry-pdp__back { font-size: 1.4rem; }
    .hngry-pdp__title { font-size: clamp(4.5rem, 5vw, 6.5rem); }
    .hngry-pdp__sublabel { font-size: 1.5rem; }
    .hngry-pdp__price { font-size: 2.8rem; }
    .hngry-pdp__desc { font-size: 1.8rem; line-height: 1.7; }
    .hngry-pdp__variants-label { font-size: 1.5rem; }
    .hngry-pdp__size span { font-size: 1.6rem; padding: 1.1rem 1.7rem; min-width: 5.5rem; }
    .hngry-pdp__add { font-size: 1.7rem; padding: 1.6rem; }
    .hngry-pdp__details-label { font-size: 1.5rem; }
    .hngry-pdp__details-list li { font-size: 1.4rem; line-height: 2; }
  }
{% endstyle %}

{% schema %}
{
  "name": "HNGRY Product",
  "settings": [
    { "type": "text", "id": "sub_label", "label": "Sub-label", "default": "WHITE / DROP 001" },
    { "type": "text", "id": "badge", "label": "Badge", "info": "Hidden automatically when the product is sold out.", "default": "NEW" },
    {
      "type": "textarea",
      "id": "details",
      "label": "Details (one per line)",
      "default": "280 GSM heavyweight cotton\nBoxy oversized fit — size down for regular\nPuff print front, screen print back\nWoven HNGRŸ label at hem"
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ]
}
{% endschema %}
