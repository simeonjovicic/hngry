{%- liquid
  if section.settings.image != blank
    assign hero_img = section.settings.image | image_url: width: 2400
    assign hero_alt = section.settings.image.alt | default: shop.name
  else
    assign hero_img = 'hngry-hero-sky.jpg' | asset_url
    assign hero_alt = shop.name
  endif
-%}

<section class="hngry-hero" style="--hero-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};">
  <img
    src="{{ hero_img }}"
    alt="{{ hero_alt | escape }}"
    class="hngry-hero__img"
    width="1600"
    height="900"
    fetchpriority="high"
  >
  <div class="hngry-hero__scrim"></div>

  <div class="hngry-hero__overlay">
    <div class="hngry-hero__top hngry-mono">
      <span class="hngry-hero-enter hngry-hero-enter--top-left">{{ section.settings.label_left }}</span>
      <span class="hngry-hero__top-right hngry-hero-enter hngry-hero-enter--top-right">{{ section.settings.label_right }}</span>
    </div>

    <div class="hngry-hero__foot">
      <div class="hngry-hero__headline-block">
        <h1 class="hngry-hero__headline hngry-display hngry-hero-enter hngry-hero-enter--headline">{{ section.settings.heading }}</h1>
        {%- if section.settings.subline != blank -%}
          <p class="hngry-hero__subline hngry-mono hngry-hero-enter hngry-hero-enter--subline">{{ section.settings.subline }}</p>
        {%- endif -%}
      </div>
      <div class="hngry-hero__ctas hngry-hero-enter hngry-hero-enter--ctas">
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="hngry-hero__cta hngry-mono">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.link_label != blank -%}
          <a href="{{ section.settings.link_url | default: routes.all_products_collection_url }}" class="hngry-hero__link hngry-mono">
            {{ section.settings.link_label }} →
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <span class="hngry-hero__scroll hngry-mono">SCROLL ↓</span>
</section>

{% style %}
  @keyframes hngry-hero-enter {
    from { opacity: 0; transform: translateY(4rem); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes hngry-hero-image-enter {
    from { transform: scale(1.045); }
    to { transform: scale(1); }
  }

  .hngry-hero {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    /* slide up under the transparent header so it overlays the image */
    margin-top: calc(-1 * var(--header-height, 5.5rem));
    /* Fill the first screen on every device. The header overlays the image,
       so only the ticker height needs to be removed from the viewport. */
    height: calc(100vh - 3.2rem);
    height: calc(100svh - 3.2rem);
    aspect-ratio: auto;
    min-height: 42rem;
    overflow: hidden;
    background: var(--hngry-ink);
  }

  .hngry-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .hngry-home .hngry-hero__img {
    animation: hngry-hero-image-enter 1.8s cubic-bezier(0.16, 1, 0.3, 1) 0.48s both;
  }

  .hngry-home .hngry-hero-enter {
    animation: hngry-hero-enter 0.95s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hngry-home .hngry-hero-enter--headline { animation-delay: 0.82s; }
  .hngry-home .hngry-hero-enter--subline { animation-delay: 0.98s; }
  .hngry-home .hngry-hero-enter--ctas { animation-delay: 1.12s; }
  .hngry-home .hngry-hero-enter--top-left { animation-delay: 1.38s; }
  .hngry-home .hngry-hero-enter--top-right { animation-delay: 1.52s; }

  @media (max-width: 749px) {
    .hngry-hero__img {
      object-position: 25% center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hngry-home .hngry-hero__img,
    .hngry-home .hngry-hero-enter {
      animation: none;
    }
  }

  .shopify-design-mode .hngry-home .hngry-hero__img,
  .shopify-design-mode .hngry-home .hngry-hero-enter {
    animation: none;
  }

  /* dark scrim so the mono labels/buttons stay legible over the photo;
     doubled class beats Dawn's `div:empty { display: none }` in base.css */
  .hngry-hero .hngry-hero__scrim {
    display: block;
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(12, 12, 12, calc(var(--hero-overlay) * 0.9)) 0%,
      rgba(12, 12, 12, calc(var(--hero-overlay) * 0.15)) 35%,
      rgba(12, 12, 12, calc(var(--hero-overlay) * 0.55)) 100%
    );
  }

  .hngry-hero__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 1.8rem;
    padding: 2.5rem;
    color: var(--hngry-bone);
    pointer-events: none;
  }

  /* top labels sit out of flow, clear of the overlaid header */
  .hngry-hero__top {
    position: absolute;
    top: calc(2.5rem + var(--header-height, 5.5rem));
    left: 2.5rem;
    right: 2.5rem;
    display: flex;
    justify-content: space-between;
    font-size: 1.1rem;
  }

  @media (max-width: 749px) {
    /* header covers this label on mobile — hide the whole top row */
    .hngry-hero__top { display: none; }
    .hngry-hero__overlay { padding: 1.5rem; gap: 1.2rem; }
  }

  /* bottom block: headline, subline and CTAs stacked bottom-left */
  .hngry-hero__foot {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2.4rem;
  }

  .hngry-hero__ctas {
    display: flex;
    align-items: center;
    gap: 2rem;
    pointer-events: auto;
  }

  .hngry-hero__headline {
    margin: 0;
    font-size: clamp(3.2rem, 6.5vw, 7.2rem);
    line-height: 0.95;
    text-transform: uppercase;
    white-space: pre-line;
    color: var(--hngry-bone);
  }

  .hngry-hero__subline {
    margin: 1rem 0 0;
    font-size: 1.1rem;
    color: rgba(241, 239, 233, 0.8);
  }

  .hngry-hero__cta {
    display: inline-block;
    background: var(--hngry-bone);
    color: var(--hngry-ink);
    padding: 1.6rem 4rem;
    font-size: 1.3rem;
    letter-spacing: 0.25em;
    text-decoration: none;
    transition: background-color 0.2s, color 0.2s;
  }

  .hngry-hero__cta:hover {
    background: var(--hngry-tag);
    color: var(--hngry-bone);
  }

  .hngry-hero__link {
    font-size: 1.2rem;
    color: var(--hngry-bone);
    text-decoration: underline;
    text-underline-offset: 0.8rem;
    white-space: nowrap;
  }

  @media (max-width: 749px) {
    .hngry-hero__foot {
      align-items: stretch;
      gap: 1.6rem;
    }
    .hngry-hero__subline { display: none; }
    .hngry-hero__link { display: none; }
    .hngry-hero__cta { text-align: center; }
  }

  @keyframes hngry-scroll-hint {
    0%, 100% { transform: translate(-50%, 0); opacity: 0.5; }
    50% { transform: translate(-50%, 6px); opacity: 1; }
  }

  .hngry-hero__scroll {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    color: var(--hngry-bone);
    font-size: 1rem;
    animation: hngry-scroll-hint 1.8s ease-in-out infinite;
  }

  @media (max-width: 749px) {
    .hngry-hero__scroll { display: none; }
  }
{% endstyle %}

{% schema %}
{
  "name": "HNGRY Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image (desktop)",
      "info": "Full-bleed background. Falls back to the bundled campaign shot."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Darken image",
      "default": 35
    },
    {
      "type": "text",
      "id": "label_left",
      "label": "Top left label",
      "default": "EST. 2026 — CLOTHES FOR THE HUNGRY"
    },
    {
      "type": "text",
      "id": "label_right",
      "label": "Top right label",
      "default": "DROP 001 / SUMMER 26"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Headline",
      "default": "Too flyyy\nfor a 9–5."
    },
    {
      "type": "text",
      "id": "subline",
      "label": "Subline",
      "default": "HEAVYWEIGHT DROP 001 — LIVE 20.07."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP DROP 001"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Secondary link label",
      "default": "EXPLORE"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Secondary link"
    }
  ],
  "presets": [{ "name": "HNGRY Hero" }]
}
{% endschema %}
