<script src="{{ 'hngry-reveal.js' | asset_url }}" defer></script>
<script src="{{ 'hngry-collections.js' | asset_url }}" defer></script>

<section
  class="hngry-collections color-{{ section.settings.color_scheme }}"
  data-hngry-carousel
  data-autoplay="{{ section.settings.autoplay_seconds | default: 4 }}"
  {{ section.shopify_attributes }}
>
  <div class="page-width">
    <div class="hngry-collections__head hngry-reveal">
      <p class="hngry-collections__label hngry-mono">{{ section.settings.label }}</p>
      <div class="hngry-collections__head-row">
        <h2 class="hngry-collections__heading hngry-display">
          {{ section.settings.heading_line1 }} <span class="hngry-outline--bone">{{ section.settings.heading_word }}</span>
        </h2>
        {%- if section.settings.view_all_url != blank -%}
          <a href="{{ section.settings.view_all_url }}" class="hngry-collections__view-all hngry-mono">VIEW ALL →</a>
        {%- endif -%}
      </div>
    </div>

    <div class="hngry-collections__grid" data-carousel-track>
      {%- for block in section.blocks -%}
        {%- liquid
          assign tile_image = block.settings.image
          if block.settings.collection != blank
            assign col = collections[block.settings.collection]
            if tile_image == blank
              assign tile_image = col.featured_image
            endif
            # fall back to the collection's first product image if no featured image is set
            if tile_image == blank and col.products.first
              assign tile_image = col.products.first.featured_image
            endif
            assign tile_link = col.url
          endif
          if block.settings.link != blank
            assign tile_link = block.settings.link
          endif
          assign tile_link = tile_link | default: routes.all_products_collection_url
        -%}
        <a href="{{ tile_link }}" class="hngry-collections__tile hngry-reveal" style="transition-delay: {{ forloop.index0 | times: 120 }}ms" {{ block.shopify_attributes }}>
          <div class="hngry-collections__media">
            {%- if tile_image != blank -%}
              {{ tile_image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'hngry-collections__img', alt: block.settings.title }}
            {%- else -%}
              <div class="hngry-collections__placeholder">{{ 'image' | placeholder_svg_tag: 'hngry-collections__placeholder-svg' }}</div>
            {%- endif -%}
            <span class="hngry-collections__cta hngry-mono">SHOP {{ block.settings.title }} →</span>
          </div>
          <div class="hngry-collections__info">
            <h3 class="hngry-collections__tile-title hngry-display">{{ block.settings.title }}</h3>
            <p class="hngry-collections__tile-sub hngry-mono">{{ block.settings.subtitle }}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      <div class="hngry-collections__progress" data-carousel-progress aria-hidden="true">
        {%- for block in section.blocks -%}
          <button class="hngry-collections__dot" data-carousel-dot data-index="{{ forloop.index0 }}">
            <span class="hngry-collections__dot-fill"></span>
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% style %}
  .hngry-collections {
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    padding: 6rem 0;
  }

  .hngry-collections__label {
    font-size: 1.1rem;
    letter-spacing: 0.3em;
    opacity: 0.4;
    margin: 0 0 1rem;
  }

  .hngry-collections__head-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .hngry-collections__heading {
    font-size: clamp(3.4rem, 7vw, 7rem);
    margin: 0;
  }

  .hngry-collections__view-all {
    font-size: 1.1rem;
    text-decoration: underline;
    text-underline-offset: 0.8rem;
    white-space: nowrap;
  }

  @media (max-width: 749px) {
    .hngry-collections__view-all { display: none; }
  }

  .hngry-collections__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.6rem 1.6rem;
  }

  @media (min-width: 990px) {
    .hngry-collections__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem 1.6rem;
    }
    .hngry-collections__tile:nth-child(3n + 2) {
      transform: translateY(4rem);
    }
    .hngry-collections__tile:nth-child(3n + 2).is-visible {
      transform: translateY(4rem);
    }
  }

  .hngry-collections__tile {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .hngry-collections__media {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    /* light frame so full product photos (white bg) sit cleanly */
    background: var(--hngry-bone);
  }

  .hngry-collections__img,
  .hngry-collections__placeholder {
    width: 100%;
    height: 100%;
    /* show the whole product, never crop the tee */
    object-fit: contain;
    transition: transform 0.5s ease;
  }

  .hngry-collections__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.25;
  }

  .hngry-collections__placeholder-svg {
    width: 60%;
    height: 60%;
  }

  .hngry-collections__tile:hover .hngry-collections__img,
  .hngry-collections__tile:hover .hngry-collections__placeholder {
    transform: scale(1.05) rotate(-2deg);
  }

  .hngry-collections__cta {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    transform: translateY(100%);
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    text-align: center;
    padding: 0.8rem 0;
    font-size: 1.1rem;
    transition: transform 0.3s ease;
  }

  .hngry-collections__tile:hover .hngry-collections__cta {
    transform: translateY(0);
  }

  .hngry-collections__info {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.2rem;
  }

  .hngry-collections__tile-title {
    font-size: 2rem;
    margin: 0;
  }

  .hngry-collections__tile-sub {
    font-size: 1rem;
    letter-spacing: 0.2em;
    opacity: 0.5;
    margin: 0.4rem 0 0;
    text-align: right;
  }

  /* progress bar hidden on desktop (grid layout) */
  .hngry-collections__progress {
    display: none;
  }

  /* ---- mobile: horizontal auto-advancing carousel ---- */
  @media (max-width: 749px) {
    .hngry-collections__grid {
      grid-template-columns: none;
      display: flex;
      gap: 0;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .hngry-collections__grid::-webkit-scrollbar {
      display: none;
    }
    .hngry-collections__tile {
      flex: 0 0 100%;
      width: 100%;
      scroll-snap-align: center;
      /* neutralise the desktop reveal offset inside the scroller */
      transform: none !important;
    }
    /* ~25% shorter than square so the carousel isn't so tall */
    .hngry-collections__media {
      aspect-ratio: 4 / 3;
    }
    .hngry-collections__progress {
      display: flex;
      gap: 0.6rem;
      margin-top: 1.6rem;
      padding: 0;
    }
    .hngry-collections__dot {
      flex: 1;
      height: 2px;
      padding: 0;
      border: none;
      background: rgba(255, 255, 255, 0.25);
      cursor: pointer;
      overflow: hidden;
    }
    .hngry-collections__dot-fill {
      display: block;
      height: 100%;
      width: 0;
      background: var(--hngry-bone);
    }
    .hngry-collections__dot.is-active .hngry-collections__dot-fill {
      width: 100%;
      transition: width var(--hngry-autoplay, 4s) linear;
    }
    .hngry-collections__dot.is-done .hngry-collections__dot-fill {
      width: 100%;
      transition: none;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "HNGRY Collections",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "(01) — THE ARSENAL" },
    { "type": "text", "id": "heading_line1", "label": "Heading start", "default": "Choose Your" },
    { "type": "text", "id": "heading_word", "label": "Heading word (outlined)", "default": "Weapon" },
    { "type": "url", "id": "view_all_url", "label": "View all link" },
    { "type": "range", "id": "autoplay_seconds", "min": 2, "max": 8, "step": 1, "unit": "s", "label": "Mobile carousel auto-advance", "default": 4 },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-3"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Category tile",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "TEES" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "HEAVYWEIGHT. BOXY. LOUD." },
        { "type": "collection", "id": "collection", "label": "Collection", "info": "Used for image + link if set" },
        { "type": "image_picker", "id": "image", "label": "Image override" },
        { "type": "url", "id": "link", "label": "Link override" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "HNGRY Collections",
      "blocks": [
        { "type": "tile", "settings": { "title": "TEES", "subtitle": "HEAVYWEIGHT. BOXY. LOUD." } },
        { "type": "tile", "settings": { "title": "HOODIES", "subtitle": "WASHED. FADED. OVERSIZED." } },
        { "type": "tile", "settings": { "title": "DROP 001", "subtitle": "THE FIRST STATEMENT." } }
      ]
    }
  ]
}
{% endschema %}
