{%- liquid
  assign line1 = section.settings.line1
  assign line2 = section.settings.line2
-%}

<section class="hngry-marquee color-{{ section.settings.color_scheme }} hngry-reveal hngry-reveal--soft" {{ section.shopify_attributes }}>
  <p class="hngry-marquee__line hngry-marquee__line--forward hngry-display" data-marquee-line>
    <span><span data-marquee-anchor>{{ line1 }}</span>&nbsp;✦&nbsp;{%- for i in (2..8) -%}{{ line1 }}&nbsp;✦&nbsp;{%- endfor -%}</span>
    <span aria-hidden="true">{%- for i in (1..8) -%}{{ line1 }}&nbsp;✦&nbsp;{%- endfor -%}</span>
  </p>
  <p class="hngry-marquee__line hngry-marquee__line--reverse hngry-marquee__line--outline hngry-display" data-marquee-line>
    <span><span data-marquee-anchor>{{ line2 }}</span>&nbsp;✦&nbsp;{%- for i in (2..8) -%}{{ line2 }}&nbsp;✦&nbsp;{%- endfor -%}</span>
    <span aria-hidden="true">{%- for i in (1..8) -%}{{ line2 }}&nbsp;✦&nbsp;{%- endfor -%}</span>
  </p>
</section>

<script>
  (function () {
    function centerMarquee(section) {
      var lines = section.querySelectorAll('[data-marquee-line]');

      lines.forEach(function (line) {
        line.style.animation = 'none';
        line.style.transform = 'none';
      });

      requestAnimationFrame(function () {
        lines.forEach(function (line) {
          var anchor = line.querySelector('[data-marquee-anchor]');
          if (!anchor) return;
          var rect = anchor.getBoundingClientRect();
          var centeredStart = window.innerWidth / 2 - (rect.left + rect.width / 2);
          line.style.setProperty('--hngry-marquee-start', centeredStart + 'px');
          line.style.animation = '';
          line.style.transform = '';
        });
        section.classList.add('hngry-marquee--ready');
      });
    }

    function boot(scope) {
      (scope || document).querySelectorAll('.hngry-marquee').forEach(centerMarquee);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () { boot(document); }, { once: true });
    } else {
      boot(document);
    }

    var resizeTimer;
    window.addEventListener('resize', function () {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(function () { boot(document); }, 150);
    });

    document.addEventListener('shopify:section:load', function (event) { boot(event.target); });
  })();
</script>

{% style %}
  @keyframes hngry-marquee-forward {
    from { transform: translateX(var(--hngry-marquee-start, 0px)); }
    to { transform: translateX(calc(var(--hngry-marquee-start, 0px) - 50%)); }
  }

  @keyframes hngry-marquee-reverse {
    from { transform: translateX(calc(var(--hngry-marquee-start, 0px) - 50%)); }
    to { transform: translateX(var(--hngry-marquee-start, 0px)); }
  }

  .hngry-marquee {
    overflow: hidden;
    padding: 1.35rem 0;
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    border-top: 1px solid rgb(var(--color-foreground));
    border-bottom: 1px solid rgb(var(--color-foreground));
  }

  .hngry-marquee__line {
    display: flex;
    width: max-content;
    white-space: nowrap;
    margin: 0;
    font-size: clamp(1.7rem, 3.75vw, 3.4rem);
    animation-play-state: paused;
    will-change: transform;
  }

  .hngry-marquee__line--forward {
    animation: hngry-marquee-forward 160s linear infinite;
  }

  .hngry-marquee__line--reverse {
    animation: hngry-marquee-reverse 123s linear infinite;
  }

  .hngry-marquee:not(.is-visible) .hngry-marquee__line {
    animation-play-state: paused;
  }

  .hngry-marquee.is-visible .hngry-marquee__line {
    animation-play-state: running;
  }

  .hngry-marquee__line--outline {
    margin-top: 0.4rem;
    -webkit-text-stroke: 1px rgb(var(--color-foreground));
    color: transparent;
  }

  @media (prefers-reduced-motion: reduce) {
    .hngry-marquee__line {
      animation: none;
      transform: translateX(var(--hngry-marquee-start, 0px));
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "HNGRY Marquee",
  "settings": [
    {
      "type": "text",
      "id": "line1",
      "label": "Line 1 (filled)",
      "default": "TOO FLYYY FOR A 9–5"
    },
    {
      "type": "text",
      "id": "line2",
      "label": "Line 2 (outlined)",
      "default": "STAY HNGRŸ"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [{ "name": "HNGRY Marquee" }]
}
{% endschema %}
