{%- liquid
  if section.settings.logo != blank
    assign logo_url = section.settings.logo | image_url: width: 400
  else
    assign logo_url = 'hngry-logo-wordmark.png' | asset_url
  endif
-%}

<footer class="hngry-footer color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <div class="hngry-footer__grid">
      {%- comment -%} Brand column {%- endcomment -%}
      <div class="hngry-footer__col hngry-footer__brand">
        <img src="{{ logo_url }}" alt="{{ shop.name | escape }}" class="hngry-footer__logo hngry-logo-invert" width="180" height="96">
        <p class="hngry-footer__tagline hngry-mono">{{ section.settings.tagline }}</p>
      </div>

      {%- comment -%} Customer service {%- endcomment -%}
      <div class="hngry-footer__col">
        <p class="hngry-footer__heading hngry-mono">{{ section.settings.col1_title }}</p>
        <ul class="hngry-footer__links">
          {%- for i in (1..4) -%}
            {%- assign label_key = 'col1_label_' | append: i -%}
            {%- assign url_key = 'col1_url_' | append: i -%}
            {%- assign label = section.settings[label_key] -%}
            {%- if label != blank -%}
              <li><a href="{{ section.settings[url_key] | default: '#' }}" class="hngry-footer__link hngry-mono">{{ label }}</a></li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      {%- comment -%} Socials {%- endcomment -%}
      <div class="hngry-footer__col">
        <p class="hngry-footer__heading hngry-mono">{{ section.settings.socials_title }}</p>
        <ul class="hngry-footer__links">
          {%- if section.settings.instagram_url != blank or section.settings.show_placeholder_socials -%}
            <li><a href="{{ section.settings.instagram_url | default: '#' }}" class="hngry-footer__link hngry-mono" target="_blank" rel="noopener">INSTAGRAM</a></li>
          {%- endif -%}
          {%- if section.settings.tiktok_url != blank or section.settings.show_placeholder_socials -%}
            <li><a href="{{ section.settings.tiktok_url | default: '#' }}" class="hngry-footer__link hngry-mono" target="_blank" rel="noopener">TIKTOK</a></li>
          {%- endif -%}
          {%- if section.settings.whatsapp_url != blank or section.settings.show_placeholder_socials -%}
            <li><a href="{{ section.settings.whatsapp_url | default: '#' }}" class="hngry-footer__link hngry-mono" target="_blank" rel="noopener">WHATSAPP</a></li>
          {%- endif -%}
        </ul>
      </div>

      {%- comment -%} Newsletter {%- endcomment -%}
      <div class="hngry-footer__col hngry-footer__signup">
        <p class="hngry-footer__heading hngry-mono">{{ section.settings.newsletter_title }}</p>
        {%- form 'customer', class: 'hngry-footer__form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          {%- if form.posted_successfully? -%}
            <p class="hngry-footer__done hngry-mono">YOU'RE IN. STAY HNGRŸ. ✦</p>
          {%- else -%}
            <div class="hngry-footer__form-row">
              <input type="email" name="contact[email]" required placeholder="ENTER YOUR EMAIL" autocomplete="email" class="hngry-footer__input hngry-mono">
              <button type="submit" class="hngry-footer__submit hngry-mono">SUBSCRIBE</button>
            </div>
            {%- if form.errors -%}<p class="hngry-footer__error hngry-mono">TRY AGAIN.</p>{%- endif -%}
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>

    <div class="hngry-footer__bottom">
      <small class="hngry-footer__copy hngry-mono">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }} — ALL RIGHTS RESERVED</small>
      <nav class="hngry-footer__legal">
        {%- for i in (1..4) -%}
          {%- assign l_key = 'legal_label_' | append: i -%}
          {%- assign u_key = 'legal_url_' | append: i -%}
          {%- assign l_label = section.settings[l_key] -%}
          {%- if l_label != blank -%}
            <a href="{{ section.settings[u_key] | default: '#' }}" class="hngry-footer__legal-link hngry-mono">{{ l_label }}</a>
          {%- endif -%}
        {%- endfor -%}
      </nav>
      <small class="hngry-footer__powered hngry-mono">POWERED BY <a href="https://hango.at" target="_blank" rel="noopener" class="hngry-footer-credit">HANGO.AT</a></small>
    </div>
  </div>
</footer>

{% style %}
  .hngry-footer {
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    padding: 5rem 0 2.5rem;
  }

  .hngry-footer__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.4fr;
    gap: 3rem;
  }

  @media (max-width: 989px) {
    .hngry-footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem 2rem;
    }
    .hngry-footer__brand,
    .hngry-footer__signup {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 749px) {
    .hngry-footer { padding: 3.5rem 0 2rem; }
    .hngry-footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem 1.5rem;
    }
  }

  .hngry-footer__logo {
    width: 14rem;
    height: auto;
  }

  .hngry-footer__tagline {
    max-width: 28rem;
    margin: 1.4rem 0 0;
    font-size: 1rem;
    line-height: 1.8;
    letter-spacing: 0.12em;
    opacity: 0.5;
  }

  .hngry-footer__heading {
    font-size: 1.1rem;
    letter-spacing: 0.25em;
    opacity: 0.45;
    margin: 0 0 1.6rem;
  }

  .hngry-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hngry-footer__link {
    font-size: 1.2rem;
    letter-spacing: 0.12em;
    color: rgb(var(--color-foreground));
    text-decoration: none;
    opacity: 0.85;
    transition: opacity 0.2s;
  }

  .hngry-footer__link:hover {
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 0.3em;
  }

  .hngry-footer__form-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.4);
    padding-bottom: 0.6rem;
  }

  .hngry-footer__input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: none;
    border-radius: 0;
    color: rgb(var(--color-foreground));
    font-size: 1.2rem;
    letter-spacing: 0.15em;
    outline: none;
  }

  .hngry-footer__input::placeholder {
    color: rgba(var(--color-foreground), 0.4);
  }

  .hngry-footer__submit {
    background: none;
    border: none;
    padding: 0;
    color: rgb(var(--color-foreground));
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.2s;
  }

  .hngry-footer__submit:hover {
    color: var(--hngry-tag);
  }

  .hngry-footer__done {
    font-size: 1.2rem;
    margin: 0;
  }

  .hngry-footer__error {
    font-size: 1rem;
    color: var(--hngry-tag);
    margin: 0.6rem 0 0;
  }

  .hngry-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.2rem;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(var(--color-foreground), 0.15);
  }

  .hngry-footer__copy,
  .hngry-footer__powered {
    font-size: 1rem;
    letter-spacing: 0.18em;
    opacity: 0.5;
  }

  .hngry-footer__legal {
    display: flex;
    flex-wrap: wrap;
    gap: 1.6rem;
  }

  .hngry-footer__legal-link {
    font-size: 1rem;
    letter-spacing: 0.18em;
    color: rgb(var(--color-foreground));
    text-decoration: none;
    opacity: 0.5;
    transition: opacity 0.2s;
  }

  .hngry-footer__legal-link:hover {
    opacity: 1;
  }

  @media (max-width: 749px) {
    .hngry-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "HNGRY Footer",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo (fallback: bundled)" },
    { "type": "textarea", "id": "tagline", "label": "Tagline", "default": "CLOTHES FOR THE ONES WHO WANT MORE. EST. 2026." },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-3" },

    { "type": "header", "content": "Customer service column" },
    { "type": "text", "id": "col1_title", "label": "Title", "default": "CUSTOMER SERVICE" },
    { "type": "text", "id": "col1_label_1", "label": "Link 1 label", "default": "SHIPPING" },
    { "type": "url", "id": "col1_url_1", "label": "Link 1 url" },
    { "type": "text", "id": "col1_label_2", "label": "Link 2 label", "default": "RETURNS" },
    { "type": "url", "id": "col1_url_2", "label": "Link 2 url" },
    { "type": "text", "id": "col1_label_3", "label": "Link 3 label", "default": "FAQ" },
    { "type": "url", "id": "col1_url_3", "label": "Link 3 url" },
    { "type": "text", "id": "col1_label_4", "label": "Link 4 label" },
    { "type": "url", "id": "col1_url_4", "label": "Link 4 url" },

    { "type": "header", "content": "Socials column" },
    { "type": "text", "id": "socials_title", "label": "Title", "default": "SOCIALS" },
    { "type": "checkbox", "id": "show_placeholder_socials", "label": "Show all social links even without URL", "default": true },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "tiktok_url", "label": "TikTok URL" },
    { "type": "url", "id": "whatsapp_url", "label": "WhatsApp URL" },

    { "type": "header", "content": "Newsletter column" },
    { "type": "text", "id": "newsletter_title", "label": "Title", "default": "SIGN UP FOR EARLY ACCESS" },

    { "type": "header", "content": "Legal bar" },
    { "type": "text", "id": "legal_label_1", "label": "Legal 1 label", "default": "DATENSCHUTZ" },
    { "type": "url", "id": "legal_url_1", "label": "Legal 1 url" },
    { "type": "text", "id": "legal_label_2", "label": "Legal 2 label", "default": "AGB" },
    { "type": "url", "id": "legal_url_2", "label": "Legal 2 url" },
    { "type": "text", "id": "legal_label_3", "label": "Legal 3 label", "default": "IMPRESSUM" },
    { "type": "url", "id": "legal_url_3", "label": "Legal 3 url" },
    { "type": "text", "id": "legal_label_4", "label": "Legal 4 label" },
    { "type": "url", "id": "legal_url_4", "label": "Legal 4 url" }
  ]
}
{% endschema %}
